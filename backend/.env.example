# ─── Base de données PostgreSQL (Render) ───────────────────────────
# Copiez l'URL depuis Render Dashboard > votre DB > Connection String
DATABASE_URL=postgresql://user:password@host:5432/etdv_eglise_db?sslmode=require

# ─── JWT ──────────────────────────────────────────────────────────
# Générez un secret fort: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=changez_moi_avec_un_secret_tres_long_et_aleatoire

# ─── Cloudinary (upload de médias) ───────────────────────────────
# Créez un compte sur cloudinary.com, copiez depuis Dashboard
CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=votre_api_key
CLOUDINARY_API_SECRET=votre_api_secret

# ─── CORS ─────────────────────────────────────────────────────────
# URL de votre frontend Vercel (et localhost pour dev)
ALLOWED_ORIGINS=http://localhost:5173,https://votre-app.vercel.app

# ─── Email (optionnel - pour le formulaire de contact) ────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre@gmail.com
SMTP_PASS=votre_app_password_gmail
CONTACT_EMAIL=eglise@votredomaine.com

# ─── Environnement ────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
